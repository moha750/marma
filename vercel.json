{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard", "destination": "/app.html" },
    { "source": "/calendar", "destination": "/app.html" },
    { "source": "/bookings", "destination": "/app.html" },
    { "source": "/customers", "destination": "/app.html" },
    { "source": "/customers/:id", "destination": "/app.html" },
    { "source": "/fields", "destination": "/app.html" },
    { "source": "/schedule", "destination": "/app.html" },
    { "source": "/reports", "destination": "/app.html" },
    { "source": "/staff", "destination": "/app.html" },
    { "source": "/subscription", "destination": "/app.html" }
  ]
}
